{
  "expo": {
    "name": "Niyama Life",
    "slug": "niyama-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "scheme": "niyamalife",
    "icon": "./assets/niyama-icon.png",
    "splash": {
      "image": "./assets/niyama-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F7F4"
    },
    "ios": {
      "icon": "./assets/niyama-icon.png",
      "supportsTablet": false,
      "bundleIdentifier": "com.niyamalife.app",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Niyama Life reads your health data to automatically verify habits like sleep, steps, and stand hours.",
        "NSHealthUpdateUsageDescription": "Niyama Life does not write health data.",
        "NSUserTrackingUsageDescription": "Niyama Life uses anonymised analytics to improve the app experience.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.healthkit": true,
        "com.apple.developer.healthkit.background-delivery": true
      }
    },
    "android": {
      "package": "com.niyamalife.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/niyama-icon.png",
        "backgroundColor": "#4A7A68"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo-google-fonts/dm-sans/400Regular/DMSans_400Regular.ttf",
            "./node_modules/@expo-google-fonts/dm-sans/500Medium/DMSans_500Medium.ttf",
            "./node_modules/@expo-google-fonts/dm-sans/600SemiBold/DMSans_600SemiBold.ttf",
            "./node_modules/@expo-google-fonts/dm-sans/700Bold/DMSans_700Bold.ttf"
          ]
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#4A7A68",
          "defaultChannel": "niyama"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "niyama-life",
          "project": "niyama-mobile"
        }
      ],
      "@sentry/react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "4e63bf48-bd24-42b9-b438-046dc917dea8"
      }
    }
  }
}
